{
  "_comment": "Inline policy 'DeployPipeline' attached to IAM role 'therapybill-github-deploy'. The role is assumed by GitHub Actions via OIDC (see .github/workflows/deploy.yml). This file is the source of truth for what the role should permit — if it drifts from live, fix live to match. Update via: aws iam put-role-policy --role-name therapybill-github-deploy --policy-name DeployPipeline --policy-document file://.aws/github-deploy-policy.json",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UploadSourceZip",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::therapybill-build-source-773320320189/source.zip"
    },
    {
      "Sid": "TriggerAndPollCodeBuild",
      "Effect": "Allow",
      "Action": [
        "codebuild:StartBuild",
        "codebuild:BatchGetBuilds"
      ],
      "Resource": "arn:aws:codebuild:us-east-1:773320320189:project/therapybill-build"
    },
    {
      "Sid": "RolloutECSService",
      "Effect": "Allow",
      "Action": [
        "ecs:UpdateService",
        "ecs:DescribeServices"
      ],
      "Resource": "arn:aws:ecs:us-east-1:773320320189:service/therapybill-cluster/therapybill-service"
    },
    {
      "Sid": "DescribeTaskDefinitionForMigration",
      "Effect": "Allow",
      "Action": "ecs:DescribeTaskDefinition",
      "Resource": "*"
    },
    {
      "Sid": "RunMigrationTask",
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask",
        "ecs:DescribeTasks"
      ],
      "Resource": [
        "arn:aws:ecs:us-east-1:773320320189:task-definition/therapybill-app:*",
        "arn:aws:ecs:us-east-1:773320320189:task/therapybill-cluster/*"
      ],
      "Condition": {
        "StringEquals": {
          "ecs:cluster": "arn:aws:ecs:us-east-1:773320320189:cluster/therapybill-cluster"
        }
      }
    },
    {
      "Sid": "PassECSRolesToMigrationTask",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::773320320189:role/therapybill-ecs-execution-role",
        "arn:aws:iam::773320320189:role/therapybill-ecs-task-role"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ecs-tasks.amazonaws.com"
        }
      }
    }
  ]
}
