  // Update plan benefits manually
  app.patch('/api/patients/:patientId/plan-benefits/:benefitsId', isAuthenticated, async (req: any, res) => {
    try {
      const userId = req.user?.claims?.sub;
      const user = await storage.getUser(userId);
