  // --- Booking Settings ---
  app.get('/api/booking/settings', isAuthenticated, async (req: any, res) => {
    try {
      const practiceId = getAuthorizedPracticeId(req);
      const settings = await storage.getBookingSettings(practiceId);
      res.json(settings || {});
    } catch (error) {
