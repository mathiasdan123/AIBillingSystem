# ===========================================
# REQUIRED - Database Configuration
# ===========================================
# PostgreSQL connection string (Neon serverless recommended)
DATABASE_URL=postgres://user:password@hostname/database?sslmode=require
DIRECT_URL=postgres://user:password@hostname/database?sslmode=require

# ===========================================
# REQUIRED - Security Keys
# ===========================================
# Session secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# PHI encryption key (32-byte AES-256) - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=

# ===========================================
# OPTIONAL - Supabase (if using Supabase)
# ===========================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ===========================================
# OPTIONAL - AI Services
# ===========================================
# OpenAI API key for SOAP note generation and claim optimization
OPENAI_API_KEY=

# ElevenLabs API key for voice features
ELEVENLABS_API_KEY=

# ===========================================
# OPTIONAL - Payment Processing (Stripe)
# ===========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLIC_KEY=

# ===========================================
# OPTIONAL - Insurance/Clearinghouse Integration
# ===========================================
# Stedi API key for eligibility checks and claim submission
STEDI_API_KEY=

# ===========================================
# OPTIONAL - Email Configuration
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===========================================
# OPTIONAL - SMS (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# OPTIONAL - Error Monitoring (Sentry)
# ===========================================
# Sentry DSN for backend error tracking (Express/Node)
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# If not set, Sentry is disabled and the app runs normally without it.
SENTRY_DSN=

# Sentry DSN for frontend error tracking (React)
# This is exposed to the browser — use a separate Sentry project or the same DSN.
VITE_SENTRY_DSN=

# ===========================================
# PRODUCTION - Additional Security
# ===========================================
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://yourdomain.com

# Set to 'production' in production environment
NODE_ENV=development

# ===========================================
# OPTIONAL - Redis (Distributed Rate Limiting & Caching)
# ===========================================
# Redis connection URL for distributed rate limiting across multiple server instances.
# If not set, rate limiting uses an in-memory store (fine for single-server deployments).
# Examples:
#   redis://localhost:6379
#   redis://:password@redis-host:6379
#   rediss://user:password@redis-host:6380  (TLS)
# REDIS_URL=

# ===========================================
# OPTIONAL - Rate Limiting Configuration
# ===========================================
# Rate limit window in milliseconds (default: 900000 = 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000

# Max requests per window for general endpoints (default: 1000)
# RATE_LIMIT_MAX_GENERAL=1000

# Max requests per window for auth endpoints (default: 20)
# RATE_LIMIT_MAX_AUTH=20

# Max requests per window for API endpoints (default: 100)
# RATE_LIMIT_MAX_API=100

# API rate limit window in milliseconds (default: 60000 = 1 minute)
# API_RATE_LIMIT_WINDOW_MS=60000

# ===========================================
# OPTIONAL - API Versioning
# ===========================================
# Default API version when no version is specified via URL prefix or Accept header.
# Supported values: v1 (current). Defaults to v1 if not set.
# API_DEFAULT_VERSION=v1

# ===========================================
# PRODUCTION - Data Retention
# ===========================================
# Number of days to retain soft-deleted patient data before hard deletion.
# Default: 2555 (~7 years). Federal HIPAA requires minimum 6 years (2190 days).
# Some states require longer — check your state's medical record retention laws.
# DATA_RETENTION_DAYS=2555
